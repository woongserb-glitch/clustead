# Copy to .env and fill in. Do NOT commit .env (gitignored).

# Kakao Developers (https://developers.kakao.com)
KAKAO_JAVASCRIPT_KEY=
KAKAO_REST_API_KEY=

# 서울 열린데이터 광장 / 공공데이터포털 (데이터 수집 파이프라인용)
SEOUL_OPEN_DATA_KEY=
PUBLIC_DATA_SERVICE_KEY=

# --- 배포 보안 (외부 공개 시 중요) ---
# Werkzeug 디버거(RCE 위험)는 기본 OFF. 로컬 디버깅 시에만 1. 프로덕션은 반드시 비워둘 것.
# FLASK_DEBUG=0
# /admin/* 보호 토큰. 미설정이면 비-디버그 환경에서 admin 라우트가 404로 숨겨진다.
# 외부 공개 시 강한 랜덤값 설정 후 ?admin_token= 또는 X-Admin-Token 헤더로 접근.
# CLUSTEAD_ADMIN_TOKEN=
# 레이트리밋(Kakao 쿼터 보호). /result=30/분, export=10/분(IP 기준). 0으로 끌 수 있음.
# CLUSTEAD_RATELIMIT=1
# CLUSTEAD_RATELIMIT_STORAGE=memory://   # 다중 인스턴스 시 redis://host:6379 로 교체
# 리버스 프록시(nginx 등) 뒤 배포 시 1로 켜야 IP별 레이트리밋이 정확히 동작.
# CLUSTEAD_TRUST_PROXY=0

# --- 사용자 행동 분석 로깅 (SQLite, 비동기) ---
# 기본 ON. 끄려면 0. 방문/검색 이벤트를 data/analytics/analytics.db 에 비동기 기록.
# CLUSTEAD_ANALYTICS=1
# DB 경로(기본: data/analytics/analytics.db — 영속 볼륨 밑이라 컨테이너 재생성에도 생존).
# CLUSTEAD_ANALYTICS_DB=
# visitor_hash 솔트 시드. 미설정 시 부팅마다 랜덤(재시작 시 일별 순방문자 연속성만 끊김).
# 안정적 일별 집계를 원하면 강한 랜덤값 고정. IP 원문은 어떤 경우에도 저장되지 않음.
# CLUSTEAD_ANALYTICS_SALT=

# --- optional runtime toggles (defaults shown) ---
# CLUSTEAD_KAKAO_RESULT_MODE=        # off | all | (빈값=cafe/convenience/mart만)
# CLUSTEAD_KAKAO_CACHE=1
# CLUSTEAD_KAKAO_CACHE_TTL=2592000
# CLUSTEAD_PRELOAD_VERBOSE=0
# CLUSTEAD_DEBUG=0
