# Copy to .env and fill in. Do NOT commit .env (gitignored).

# Kakao Developers (https://developers.kakao.com)
KAKAO_JAVASCRIPT_KEY=
KAKAO_REST_API_KEY=

# 서울 열린데이터 광장 / 공공데이터포털 (데이터 수집 파이프라인용)
SEOUL_OPEN_DATA_KEY=
PUBLIC_DATA_SERVICE_KEY=

# --- optional runtime toggles (defaults shown) ---
# LIVEFIT_KAKAO_RESULT_MODE=        # off | all | (빈값=cafe/convenience/mart만)
# LIVEFIT_KAKAO_CACHE=1
# LIVEFIT_KAKAO_CACHE_TTL=2592000
# LIVEFIT_PRELOAD_VERBOSE=0
# LIVEFIT_DEBUG=0
